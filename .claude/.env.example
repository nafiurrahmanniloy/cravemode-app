# FoodShot AI - API Keys & Configuration
# Copy this file to .env and fill in your keys:
#   cp .claude/.env.example .claude/.env

# ===== Image & Video Generation =====

# Google AI Studio API Key (for Nano Banana Pro images + Veo 3.1 videos)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Kie AI API Key (for video generation + file hosting)
# Get yours at: https://kie.ai/api-key
KIE_API_KEY=your_kie_ai_api_key_here

# ===== Project Management =====

# ClickUp Personal Access Token
# Create at: https://app.clickup.com/settings/apps
# Required scopes: workspace:read, workspace:write, task:read, task:write, list:read, list:write
CLICKUP_API_KEY=your_clickup_api_key_here

# ClickUp Workspace ID (Team ID)
# Find in ClickUp workspace settings or use the get_teams MCP tool
CLICKUP_WORKSPACE_ID=your_workspace_id_here

# ===== Automation =====

# n8n Webhook URL (for form submissions from website)
# From your n8n webhook trigger node
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/foodshot-intake

# n8n API Key (optional - only if using n8n API for workflow management)
# From n8n user settings → API
N8N_API_KEY=your_n8n_api_key_here

# n8n Instance URL (optional - for self-hosted n8n)
N8N_API_URL=https://your-n8n-instance.com/api/v1

# ===== Design & Assets =====

# Figma API Token (optional - for design asset access)
# Get at: https://www.figma.com/developers/api#access-tokens
FIGMA_API_KEY=your_figma_api_key_here

# ===== Website (Next.js) =====

# Public webhook URL for website contact form (same as N8N_WEBHOOK_URL)
# Used in site/.env.local
NEXT_PUBLIC_WEBHOOK_URL=https://your-n8n-instance.com/webhook/foodshot-intake

# ===== Optional Services =====

# Midjourney API (optional - for alternative image generation)
# Get at: https://www.midjourneyapi.io
MIDJOURNEY_API_KEY=your_midjourney_api_key_here

# Replicate API (optional - for additional AI models)
# Get at: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=your_replicate_api_key_here
